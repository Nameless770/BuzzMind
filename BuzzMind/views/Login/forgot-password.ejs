<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password - BuzzMind</title>
    <link rel="stylesheet" href="/Login Page/Login Page.css" />
  </head>

  <body>
    <main class="main-content">
      <div class="card">
        <div class="brand">BuzzMind</div>

        <div class="form-container">
          <h1>Forget Password</h1>
          <p class="sub">Write your username or email to get a reset code.</p>

          
          <form id="forgot-password-form">
            <div class="field">
              <label for="reset-email-or-username">Email or Username</label>
              <input
                name="emailOrUsername"
                id="reset-email-or-username"
                type="text"
                placeholder="alex@university.edu or arivera_pro" />
              <span id="reset-id-error" class="inline-error"></span>
            </div>

            <button id="send-code-btn" class="cta-btn" type="submit">
              Send Code
            </button>

            <p id="reset-timer" class="timer-text" aria-live="polite"></p>

            <div class="field code-field">
              <label for="reset-code">Code</label>
              <input
                name="code"
                id="reset-code"
                type="text"
                inputmode="numeric"
                maxlength="6"
                placeholder="Type the code" />
            </div>

            <div class="field">
              <label for="reset-new-password">New Password</label>
              <input
                name="newPassword"
                id="reset-new-password"
                type="password"
                placeholder="New password" />
            </div>

            <div class="field">
              <label for="reset-confirm-password">Confirm Password</label>
              <input
                name="confirmPassword"
                id="reset-confirm-password"
                type="password"
                placeholder="Confirm password" />
            </div>

            <button id="verify-code-btn" class="secondary-btn" type="button">
              Reset Password
            </button>

            <p id="reset-status" class="reset-status" aria-live="polite"></p>
          </form>

          <a class="back-link" href="/login">Back to Login</a>
        </div>
      </div>
    </main>

    <footer class="footer">
      <div class="footer-brand">
        <a href="/" class="logo footer-logo">BuzzMind</a>
        <p>
          Empowering learners and educators through kinetic, high-energy play.
        </p>
      </div>
    </footer>

    <div class="footer-bottom">
      <span>&copy; 2026 BuzzMind. All rights reserved.</span>
    </div>

    <script src="/Login Page/Login Page.js"></script>
    <script src="/shared/i18n.js"></script>
  </body>
</html>
