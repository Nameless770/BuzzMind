<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BuzzMind · Pricing</title>
  <link rel="stylesheet" href="/shared/site.css" />
</head>
<body>
  <%- include('../partials/site-nav', { active: 'pricing' }) %>

  <%
    var chk = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
  %>

  <header class="page-hero">
    <span class="eyebrow">For professors</span>
    <h1>Plans that grow with your <span class="grad">classroom</span></h1>
    <p class="lead">Start free, upgrade when your classes get bigger, and cancel anytime. Every plan includes live games, quizzes, and leaderboards.</p>
  </header>

  <section class="section tight">
    <div style="text-align:center">
      <div class="billing-toggle" role="group" aria-label="Billing period">
        <button id="billMonthly" class="active" type="button">Monthly</button>
        <button id="billAnnual" type="button">Annual&nbsp;<span class="save">Save 20%</span></button>
      </div>
    </div>

    <div class="pricing-grid">
      <!-- Starter -->
      <div class="price-card">
        <div class="tier">Starter</div>
        <div class="tier-desc">For trying things out and small classes.</div>
        <div class="price">
          <span class="currency">$</span>
          <span class="amount" data-monthly="0" data-annual="0">0</span>
          <span class="per">/mo</span>
        </div>
        <div class="billed-note" data-note-monthly="Free forever" data-note-annual="Free forever">Free forever</div>
        <ul class="feat">
          <li><%- chk %> Up to 2 classes</li>
          <li><%- chk %> Up to 50 students</li>
          <li><%- chk %> Core quiz builder</li>
          <li><%- chk %> Live games &amp; PINs</li>
          <li><%- chk %> Community support</li>
        </ul>
        <a href="/register?role=professor" class="btn btn-ghost">Get started free</a>
      </div>

      <!-- Pro -->
      <div class="price-card featured">
        <span class="badge">Most popular</span>
        <div class="tier">Pro</div>
        <div class="tier-desc">For active educators running regular live quizzes.</div>
        <div class="price">
          <span class="currency">$</span>
          <span class="amount" data-monthly="19" data-annual="15">19</span>
          <span class="per">/mo</span>
        </div>
        <div class="billed-note" data-note-monthly="Billed monthly" data-note-annual="Billed annually">Billed monthly</div>
        <ul class="feat">
          <li><%- chk %> Unlimited classes</li>
          <li><%- chk %> Up to 500 students</li>
          <li><%- chk %> Quiz library &amp; AI import</li>
          <li><%- chk %> Reports &amp; analytics</li>
          <li><%- chk %> Assignments &amp; grading</li>
          <li><%- chk %> Priority email support</li>
        </ul>
        <a href="/contact" class="btn btn-create">Contact sales</a>
      </div>

      <!-- Campus -->
      <div class="price-card">
        <div class="tier">Campus</div>
        <div class="tier-desc">For departments and whole schools.</div>
        <div class="price">
          <span class="currency">$</span>
          <span class="amount" data-monthly="99" data-annual="79">99</span>
          <span class="per">/mo</span>
        </div>
        <div class="billed-note" data-note-monthly="Billed monthly" data-note-annual="Billed annually">Billed monthly</div>
        <ul class="feat">
          <li><%- chk %> Everything in Pro</li>
          <li><%- chk %> Unlimited students</li>
          <li><%- chk %> Admin dashboard</li>
          <li><%- chk %> Custom branding</li>
          <li><%- chk %> Onboarding &amp; training</li>
          <li><%- chk %> Dedicated support</li>
        </ul>
        <a href="/contact" class="btn btn-secondary">Contact sales</a>
      </div>
    </div>

    <p class="price-note">These prices are for preview only — online billing isn't connected yet. Pick a plan and our team will set you up.</p>
  </section>

  <section class="section">
    <div class="cta-band">
      <h2>Still deciding?</h2>
      <p>Start on the free Starter plan today — no card required — and upgrade whenever you're ready.</p>
      <div class="hero-buttons" style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
        <a href="/register?role=professor" class="btn btn-create btn-lg">Create free account</a>
        <a href="/contact" class="btn btn-secondary btn-lg">Talk to us</a>
      </div>
    </div>
  </section>

  <%- include('../partials/site-footer') %>

  <script src="/shared/i18n.js"></script>
  <script>
    (function () {
      var monthlyBtn = document.getElementById('billMonthly');
      var annualBtn = document.getElementById('billAnnual');

      function setMode(mode) {
        var annual = mode === 'annual';
        document.querySelectorAll('.amount[data-monthly]').forEach(function (el) {
          el.textContent = annual ? el.getAttribute('data-annual') : el.getAttribute('data-monthly');
        });
        document.querySelectorAll('.billed-note').forEach(function (el) {
          var v = annual ? el.getAttribute('data-note-annual') : el.getAttribute('data-note-monthly');
          el.textContent = v || '';
        });
        monthlyBtn.classList.toggle('active', !annual);
        annualBtn.classList.toggle('active', annual);
        // Re-apply translation so swapped notes follow the current language.
        if (window.__buzzI18n) window.__buzzI18n.setLang(window.__buzzI18n.getLang());
      }

      monthlyBtn.addEventListener('click', function () { setMode('monthly'); });
      annualBtn.addEventListener('click', function () { setMode('annual'); });
      setMode('monthly');
    })();
  </script>
</body>
</html>
