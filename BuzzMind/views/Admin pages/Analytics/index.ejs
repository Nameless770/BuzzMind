<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BuzzMind · Analytics</title>
  <link rel="stylesheet" href="/shared/dashboard.css" />
</head>
<body>
<div class="dash-shell">
  <%- include('../../partials/admin-sidebar', { active: 'analytics' }) %>

  <div class="dash-main">
    <div class="dash-top">
      <div>
        <h1>Statistics &amp; Analytics</h1>
        <div class="sub">A live snapshot of activity across the whole platform.</div>
      </div>
      <div class="right">
        <button class="btn btn-ghost" id="refreshBtn"><span class="ic" data-icon="refresh"></span> Refresh</button>
      </div>
    </div>

    <div class="dash-content">
      <div class="stat-grid" id="statGrid">
        <div class="stat-card"><div class="lbl">Students</div><div class="num b" data-k="students">—</div></div>
        <div class="stat-card"><div class="lbl">Professors</div><div class="num p" data-k="professors">—</div></div>
        <div class="stat-card"><div class="lbl">Admins</div><div class="num a" data-k="admins">—</div></div>
        <div class="stat-card"><div class="lbl">Classes</div><div class="num" data-k="classes">—</div></div>
        <div class="stat-card"><div class="lbl">Quizzes</div><div class="num g" data-k="quizzes">—</div></div>
        <div class="stat-card"><div class="lbl">Live sessions</div><div class="num" data-k="sessions">—</div></div>
        <div class="stat-card"><div class="lbl">Assignments</div><div class="num" data-k="assignments">—</div></div>
        <div class="stat-card"><div class="lbl">Submissions</div><div class="num" data-k="submissions">—</div></div>
      </div>

      <div class="grid" style="grid-template-columns:repeat(auto-fill,minmax(360px,1fr))">
        <div class="panel" style="margin:0">
          <div class="panel-head"><h2>User roles</h2></div>
          <div id="roleBars"><div class="muted">Loading…</div></div>
        </div>

        <div class="panel" style="margin:0">
          <div class="panel-head"><h2>Professors by department</h2></div>
          <div id="deptBars"><div class="muted">Loading…</div></div>
        </div>

        <div class="panel" style="margin:0">
          <div class="panel-head"><h2>Grade distribution</h2></div>
          <div id="gradeBars"><div class="muted">Loading…</div></div>
        </div>

        <div class="panel" style="margin:0">
          <div class="panel-head"><h2>Grading progress</h2></div>
          <div id="gradeProgress"><div class="muted">Loading…</div></div>
        </div>

        <div class="panel" style="margin:0">
          <div class="panel-head"><h2>Most played quizzes</h2></div>
          <div id="topQuizzes"><div class="muted">Loading…</div></div>
        </div>

        <div class="panel" style="margin:0">
          <div class="panel-head"><h2>Recent activity</h2></div>
          <div id="activity"><div class="muted">Loading…</div></div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="/buzzmind-api.js"></script>
<script src="/buzzmind-session.js"></script>
<script src="/shared/dashboard.js"></script>
<script>
(function () {
  const E = Dash.escapeHTML;

  function barRow(label, value, max, cls) {
    const pct = max > 0 ? Math.round((value / max) * 100) : 0;
    return `<div class="bar-row">
      <div class="bl" title="${E(label)}">${E(label)}</div>
      <div class="bar"><div class="bar-fill ${cls || ''}" style="width:${pct}%"></div></div>
      <div class="bv">${value}</div>
    </div>`;
  }

  function renderBars(el, rows, cls) {
    if (!rows.length) { el.innerHTML = `<div class="muted">No data yet.</div>`; return; }
    const max = Math.max(...rows.map((r) => r.value), 1);
    el.innerHTML = rows.map((r) => barRow(r.label, r.value, max, cls)).join('');
  }

  function renderActivity(el, items) {
    if (!items.length) { el.innerHTML = `<div class="muted">No recent activity.</div>`; return; }
    const icon = { submission: 'file-text', quiz: 'list-checks', user: 'user' };
    el.innerHTML = items.map((a) => `
      <div style="display:flex;gap:10px;padding:9px 0;border-bottom:1px solid var(--line)">
        <span class="ic" style="color:var(--brand);flex:none">${Dash.icon(icon[a.type] || 'inbox')}</span>
        <div style="flex:1">
          <div style="font-size:13px">${E(a.text)}</div>
          <div class="muted" style="font-size:11px">${Dash.timeAgo(a.date)}</div>
        </div>
      </div>`).join('');
  }

  function renderQuizzes(el, items) {
    if (!items.length) { el.innerHTML = `<div class="muted">No quiz plays recorded.</div>`; return; }
    const max = Math.max(...items.map((q) => q.plays), 1);
    el.innerHTML = items.map((q) => `
      <div style="margin-bottom:14px">
        <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:5px">
          <strong style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:200px">${E(q.title || 'Untitled')}</strong>
          <span class="muted">${q.plays} plays · ${q.avgAccuracy}%</span>
        </div>
        <div class="bar"><div class="bar-fill" style="width:${Math.round((q.plays / max) * 100)}%"></div></div>
      </div>`).join('');
  }

  function renderProgress(el, s) {
    const total = s.total || 0;
    const graded = s.graded || 0;
    const pct = total > 0 ? Math.round((graded / total) * 100) : 0;
    el.innerHTML = `
      <div style="font-size:30px;font-weight:800;margin-bottom:6px">${pct}%</div>
      <div class="muted" style="margin-bottom:14px">${graded} of ${total} submissions graded</div>
      <div class="bar" style="height:14px"><div class="bar-fill g" style="width:${pct}%"></div></div>`;
  }

  async function load() {
    try {
      const a = await BuzzMindAPI.getAnalytics();
      document.querySelectorAll('[data-k]').forEach((el) => {
        const v = a.counts[el.dataset.k];
        el.textContent = (v == null ? 0 : v);
      });
      renderBars(document.getElementById('roleBars'), a.roleDistribution, 'b');
      renderBars(document.getElementById('deptBars'), a.departmentDistribution, 'p');
      renderBars(document.getElementById('gradeBars'), a.gradeDistribution, 'g');
      renderProgress(document.getElementById('gradeProgress'), a.submissionStatus || {});
      renderQuizzes(document.getElementById('topQuizzes'), a.topQuizzes || []);
      renderActivity(document.getElementById('activity'), a.recentActivity || []);
    } catch (err) {
      Dash.toast(err.message || 'Failed to load analytics', 'error');
    }
  }

  document.getElementById('refreshBtn').addEventListener('click', load);
  Dash.boot();
  load();
})();
</script>
</body>
</html>
