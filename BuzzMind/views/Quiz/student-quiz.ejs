<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BuzzMind – Quiz</title>
    <link rel="stylesheet" href="/Quiz/style.css" />
    <link rel="stylesheet" href="/Quiz/quiz.css" />
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;900&family=DM+Sans:wght@400;500&display=swap"
      rel="stylesheet" />
  </head>
  <body>
    <!-- ===== QUIZ AREA ===== -->
    <main class="quiz-main" id="quizArea">
      <!-- Question header: number + timer -->
      <div class="question-header">
        <div class="question-header-left">
          <span class="question-badge" id="questionBadge"
            >QUESTION 1 OF 10</span
          >
          <h2 class="question-text" id="questionText">Loading question...</h2>
        </div>
        <!-- Countdown timer (circular, like image 10) -->
        <div class="timer-circle" id="timerCircle">
          <svg class="timer-svg" viewBox="0 0 60 60">
            <circle class="timer-bg" cx="30" cy="30" r="26" />
            <circle class="timer-ring" id="timerRing" cx="30" cy="30" r="26" />
          </svg>
          <span class="timer-number" id="timerNumber">--:--</span>
          <span class="timer-label">TIME LEFT</span>
        </div>
      </div>

      <!-- Optional question image -->
      <div
        class="question-image-wrapper"
        id="questionImageWrapper"
        style="display: none">
        <img
          id="questionImage"
          src=""
          alt="Question image"
          class="question-img" />
      </div>

      <!-- Answer choices (4 colored tiles like image 10) -->
      <div class="answers-grid" id="answersGrid">
        <!-- Filled by JS -->
      </div>

      <!-- Feedback banner (shown after answering) -->
      <div class="feedback-banner" id="feedbackBanner" style="display: none">
        <span id="feedbackIcon"></span>
        <span id="feedbackText"></span>
      </div>

      <!-- Self-paced control: student advances themselves -->
      <button
        class="quiz-next-btn"
        id="nextQuestionBtn"
        type="button"
        style="display: none">
        Next question
      </button>
    </main>

    <!-- ===== RESULTS SCREEN (shown after all questions) ===== -->
    <section class="results-screen" id="resultsScreen" style="display: none">
      <div class="results-card">
        <div class="results-emoji"></div>
        <h2 class="results-title">Quiz Complete!</h2>
        <p class="results-score" id="resultsScore">
          You got <strong>0 / 0</strong> correct!
        </p>
        <button class="btn-join" id="resultsLeaderboardBtn" type="button">
          View leaderboard
        </button>
      </div>
    </section>

    <script src="/buzzmind-api.js"></script>
    <script src="/Quiz/quiz-data.js"></script>
    <script src="/Quiz/session-loader.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/Quiz/student-quiz.js"></script>
  </body>
</html>
